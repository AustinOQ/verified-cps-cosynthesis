    "FillingSystem": {
      "name": "FillingSystem",
      "attributes": {},
      "derived_attributes": {},
      "constraints": [
        [
          "scenarioConstraints",
          "controller.tank1TransferMl >= 0 and controller.tank2TransferMl >= 0 and\n            controller.tank1OriginalLevelMl >= 0 and controller.tank2OriginalLevelMl >= 0 and\n            controller.tank1OriginalLevelMl >= controller.tank1TransferMl and \n            controller.tank2OriginalLevelMl >= controller.tank2TransferMl"
        ],
        [
          "feeder1DrainRate",
          "feederTank1.outlet.flowRateMl == valve1.outlet.flowRateMl"
        ],
        [
          "feeder2DrainRate",
          "feederTank2.outlet.flowRateMl == valve2.outlet.flowRateMl"
        ],
        [
          "fillingFillRate",
          "fillingTank.inlet.flowRateMl == valve1.outlet.flowRateMl + valve2.outlet.flowRateMl"
        ]
      ],
      "refs": {},
      "actions": [],
      "action_defs": [],
      "bindings": [],
      "requirements": [
        [
          "No Dry Running",
          "s",
          "(s.feederTank1.currentLevelMl == 0 implies not s.pump1.isRunning) and\n                (s.feederTank2.currentLevelMl == 0 implies not s.pump2.isRunning)",
          [
            "Prohibition"
          ]
        ],
        [
          "No Dead Heading",
          "s",
          "(not s.valve1.isOpen implies not s.pump1.isRunning) and\n                (not s.valve2.isOpen implies not s.pump2.isRunning)",
          [
            "Prohibition"
          ]
        ],
        [
          "Fluid Transfer Termination Safety",
          "s",
          "(s.controller.lastScanTimeSeconds > 0) implies\n                ((s.controller.tank1OriginalLevelMl - s.feederTank1.currentLevelMl >= s.controller.tank1TransferMl)\n                  implies (not s.valve1.isOpen and not s.pump1.isRunning)) and\n                ((s.controller.tank2OriginalLevelMl - s.feederTank2.currentLevelMl >= s.controller.tank2TransferMl)\n                  implies (not s.valve2.isOpen and not s.pump2.isRunning))",
          [
            "Obligation"
          ]
        ],
        [
          "Fluid Transfer Liveness",
          "s",
          "(s.controller.lastScanTimeSeconds > 0) implies\n                ((s.controller.tank1OriginalLevelMl - s.feederTank1.currentLevelMl < s.controller.tank1TransferMl)\n                    implies (s.valve1.isOpen and s.pump1.isRunning) and \n                  (s.controller.tank2OriginalLevelMl - s.feederTank2.currentLevelMl < s.controller.tank2TransferMl)\n                    implies (s.valve2.isOpen and s.pump2.isRunning))",
          [
            "Obligation"
          ]
        ]
      ],
      "exhibits_state": null
    }
  },
